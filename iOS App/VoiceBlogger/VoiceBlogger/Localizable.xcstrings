    "VoiceBlogger needs microphone access to record audio. Please enable it in Settings." : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "VoiceBlogger necesita acceso al micrófono para grabar audio. Actívalo en Ajustes."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "VoiceBlogger a besoin d'accéder au microphone pour enregistrer de l'audio. Veuillez l'activer dans les Réglages."
          }
        },
        "gu" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "VoiceBloggerને ઑડિઓ રેકોર્ડ કરવા માટે માઇક્રોફોન ઍક્સેસની જરૂર છે. કૃપા કરીને સેટિંગ્સમાં તે ચાલુ કરો."
          }
        },
        "hi" : {
          "stringUnit" : {
