    "Record your voice and generate notes or a post to see it here." : {
      "comment" : "A description of the content that will be displayed when the user has not created any blog posts.",
      "isCommentAutoGenerated" : true
    },
    "Record yourself talking about anything — no scripts or editing needed. Even long recording... Just fine, just speak your mind!" : {
      "extractionState" : "stale",
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "Grábate hablando de lo que sea — no necesitas guiones ni edición. Incluso grabaciones largas... Está bien, ¡simplemente di lo que piensas!"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "Enregistrez-vous en parlant de n’importe quoi — pas besoin de script ni de montage. Même les longues enregistrements... C’est parfait, dites simplement ce que vous pensez !"
          }
        },
        "gu" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "ગમે તે વિષય પર બોલતાં તમારી જાતને રેકોર્ડ કરો — કોઈ સ્ક્રિપ્ટ કે એડિટિંગ જરૂરી નથી. લાંબી રેકોર્ડિંગ પણ... કોઈ વાંધો નહીં, બસ મન મૂકીને બોલો!"
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "किसी भी चीज़ के बारे में बात करते हुए खुद को रिकॉर्ड करें — कोई स्क्रिप्ट या एडिटिंग की ज़रूरत नहीं। लंबी रिकॉर्डिंग भी... बिल्कुल ठीक है, बस अपने मन की बात कहें!"
          }
        }
      }
    },
