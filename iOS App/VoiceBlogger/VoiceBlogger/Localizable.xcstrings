    "Generation failed due to a system error. The saved draft was kept; regenerate to try again." : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La generación falló por un error del sistema. Se conservó el borrador guardado; regenera para intentarlo de nuevo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La génération a échoué en raison d'une erreur système. Le brouillon enregistré a été conservé ; régénérez pour réessayer."
          }
        },
        "gu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "સિસ્ટમ ભૂલને કારણે જનરેશન નિષ્ફળ ગયું. સાચવેલું ડ્રાફ્ટ રાખવામાં આવ્યું; ફરી પ્રયાસ કરવા ફરી જનરેટ કરો."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "सिस्टम त्रुटि के कारण जनरेशन विफल हुई। सेव किया गया ड्राफ्ट रखा गया; फिर से कोशिश करने के लिए फिर से जनरेट करें।"
          }
        }
      }
    },
    "Generation produced an unexpected error. The saved draft was kept; regenerate to try again." : {
