    "Record your voice and generate notes or a post to see it here." : {
      "comment" : "A description of the content that will be displayed when the user has not created any blog posts.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "Graba tu voz y genera notas o una publicación para verlo aquí."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "Enregistrez votre voix et générez des notes ou un article pour les voir ici."
          }
        },
        "gu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "તમારો અવાજ રેકોર્ડ કરો અને તેને અહીં જોવા માટે નોંધ અથવા પોસ્ટ બનાવો."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "अपनी आवाज़ रिकॉर्ड करें और यहाँ देखने के लिए नोट्स या पोस्ट बनाएं।"
          }
        }
      }
    },
    "Record yourself talking about anything — no scripts or editing needed. Long recordings are fine too, just speak your mind!" : {
      "comment" : "A description of the recording feature.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "Grábate hablando de lo que quieras — sin guiones ni edición. Las grabaciones largas también están bien, ¡solo di lo que piensas!"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "Enregistrez-vous en parlant de n'importe quoi — aucun script ni montage nécessaire. Les enregistrements longs conviennent aussi, dites simplement ce que vous pensez !"
          }
        },
        "gu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "કંઈ પણ વિશે બોલતા રેકોર્ડ કરો — સ્ક્રિપ્ટ અથવા એડિટિંગની જરૂર નથી. લાંબી રેકોર્ડિંગ પણ ઠીક છે, ફક્ત મન મૂકીને બોલો!"
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "किसी भी बारे में बात करते हुए रिकॉर्ड करें — कोई स्क्रिप्ट या एडिटिंग की ज़रूरत नहीं। लंबी रिकॉर्डिंग भी ठीक है, बस अपने मन की बात कहें!"
          }
        }
      }
    },
