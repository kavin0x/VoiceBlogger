          }
        }
      }
    },
    "This might take a while. Feel free to keep using your phone, download happens in the background!" : {
      "comment" : "A description of the background download process.",
      "extractionState" : "stale",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "Esto puede tardar un poco. ¡Puedes seguir usando tu teléfono, la descarga ocurre en segundo plano!"
