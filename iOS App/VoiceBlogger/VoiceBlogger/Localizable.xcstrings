          }
        },
        "gu" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "અહીં જોવા માટે તમારો અવાજ રેકોર્ડ કરો અને બ્લૉગ પોસ્ટ બનાવો."
          }
