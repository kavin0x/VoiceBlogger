        "gu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "આ રેકોર્ડિંગ વાંચી શકાઈ નહીં. ઑડિઓ ફાઇલ શેર કરો અને ફરી રેકોર્ડ કરવાનો પ્રયાસ કરો."
