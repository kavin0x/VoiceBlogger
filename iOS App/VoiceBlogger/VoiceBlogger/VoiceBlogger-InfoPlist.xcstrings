    "NSMicrophoneUsageDescription" : {
      "comment" : "Privacy - Microphone Usage Description",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Voice Blogger uses the microphone to record your speech and turn it into blog posts. Your audio is processed entirely on-device and never leaves your phone."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "Voice Blogger usa el micrófono para grabar tu voz y convertirla en entradas de blog. Tu audio se procesa completamente en el dispositivo y nunca sale de tu teléfono."
          }
        },
        "gu" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "Voice Blogger તમારી વાણી રેકોર્ડ કરવા અને તેને બ્લૉગ પોસ્ટ્સમાં ફેરવવા માટે માઇક્રોફોનનો ઉપયોગ કરે છે. તમારો ઑડિઓ સંપૂર્ણ રીતે ડિવાઇસ પર જ પ્રોસેસ થાય છે અને ક્યારેય તમારા ફોનની બહાર જતો નથી."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "Voice Blogger आपकी आवाज़ रिकॉर्ड करने और उसे ब्लॉग पोस्ट में बदलने के लिए माइक्रोफ़ोन का उपयोग करता है। आपका ऑडियो पूरी तरह से डिवाइस पर ही प्रोसेस होता है और आपके फ़ोन से बाहर नहीं जाता।"
          }
        }
      }
    }
  },
  "version" : "1.3"
}